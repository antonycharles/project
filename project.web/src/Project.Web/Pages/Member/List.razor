@page "/members/project/{ProjectId:guid}"
@using Project.Web.DTOs
@using Project.Web.Enums
@using Project.Web.Services
@inject MemberService MemberService
@inject ProjectService ProjectService

<h3>Members</h3>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert @alertClass mb-3">@message</div>
}

@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mb-3">@error</div>
}

@if (project is not null)
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                <div>
                    <h5 class="card-title mb-1">@project.Name</h5>
                    <p class="text-muted mb-0">Project information</p>
                </div>
                <span class="badge @GetStatusBadgeClass(project.Status) border">@GetStatusLabel(project.Status)</span>
            </div>
            <p class="mb-1"><strong>Status:</strong> @GetStatusLabel(project.Status)</p>
            <p class="mb-1"><strong>Description:</strong> @(string.IsNullOrWhiteSpace(project.Description) ? "No description provided." : project.Description)</p>
            <p class="mb-0"><strong>Project ID:</strong> @project.Id</p>
        </div>
    </div>
}

@if (members == null)
{
    <p><em>Loading...</em></p>
}
else if (members.Count == 0)
{
    <p>No members found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>User</th>
                <th>Project</th>
                <th>Status</th>
                <th>Created At</th>
                <th>Updated At</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in members)
            {
                <tr>
                    <td>@member.UserName</td>
                    <td>
                        @if (project is not null)
                        {
                            <span>@project.Name</span>
                        }
                        else
                        {
                            <span>@member.ProjectId</span>
                        }
                    </td>
                    <td>@member.Status</td>
                    <td>@member.CreatedAt</td>
                    <td>@member.UpdatedAt</td>
                    <td>
                        <a class="btn btn-sm btn-info" href="/members/detail/@member.Id">Details</a>
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => OpenDeleteModal(member)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (showDeleteModal && memberToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Member</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteModal" disabled="@isDeleting"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Are you sure you want to delete member <strong>@(string.IsNullOrWhiteSpace(memberToDelete.UserName) ? memberToDelete.UserId.ToString() : memberToDelete.UserName)</strong>? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseDeleteModal" disabled="@isDeleting">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@isDeleting">
                        @(isDeleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public Guid ProjectId { get; set; }
    private List<MemberDto>? members;
    private ProjectDto? project;
    private string? error;
    private string? message;
    private string alertClass = "alert-success";
    private bool showDeleteModal;
    private bool isDeleting;
    private MemberDto? memberToDelete;

    private static string GetStatusLabel(StatusEnum status) => status switch
    {
        StatusEnum.Active => "Active",
        StatusEnum.Inactive => "Inactive",
        _ => status.ToString()
    };

    private static string GetStatusBadgeClass(StatusEnum status) => status switch
    {
        StatusEnum.Active => "bg-success",
        StatusEnum.Inactive => "bg-secondary",
        _ => "bg-light text-dark"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var membersTask = MemberService.GetAllAsync(ProjectId);
            var projectTask = ProjectService.Get(ProjectId);
            await Task.WhenAll(membersTask, projectTask);
            members = membersTask.Result;
            project = projectTask.Result;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void OpenDeleteModal(MemberDto member)
    {
        memberToDelete = member;
        message = null;
        error = null;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        if (isDeleting)
        {
            return;
        }

        showDeleteModal = false;
        memberToDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (memberToDelete is null || isDeleting)
        {
            return;
        }

        try
        {
            isDeleting = true;
            await MemberService.DeleteAsync(memberToDelete.Id);
            members?.RemoveAll(m => m.Id == memberToDelete.Id);
            message = "Member deleted successfully.";
            alertClass = "alert-success";
            showDeleteModal = false;
            memberToDelete = null;
        }
        catch (Exception ex)
        {
            error = $"Error deleting member: {ex.Message}";
            showDeleteModal = false;
        }
        finally
        {
            isDeleting = false;
        }
    }
}
