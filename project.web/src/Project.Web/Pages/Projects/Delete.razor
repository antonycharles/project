@page "/projects/delete/{Id:guid}"

@inject NavigationManager Navigation

<h3>Delete Project</h3>

<div class="alert alert-warning">
    Project deletion now requires confirmation from the project details page.
</div>

<div class="d-flex gap-2">
    <a class="btn btn-primary" href="/projects/@Id">Go to Details</a>
    <a class="btn btn-outline-secondary" href="/projects">Back to List</a>
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    protected override void OnInitialized()
    {
        Navigation.NavigateTo($"/projects/{Id}", true);
    }
}
