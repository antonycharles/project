@page "/projects/update/{id:guid}"
@using Project.Web.Enums
@inject ProjectService ProjectService
@inject NavigationManager Navigation

<h3>Edit Project</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @alertClass mb-3">@message</div>
}

@if (project == null)
{
    <p>Loading...</p>
}
else
{
    <EditForm Model="project" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />
        <div class="mb-3">
            <label for="name" class="form-label">Name</label>
            <InputText id="name" class="form-control" @bind-Value="project.Name" />
        </div>
        <div class="mb-3">
            <label for="description" class="form-label">Description</label>
            <InputText id="description" class="form-control" @bind-Value="project.Description" />
        </div>
        <div class="mb-3">
            <label for="status" class="form-label">Status</label>
            <InputSelect id="status" class="form-select" @bind-Value="project.Status">
                @foreach (var status in Enum.GetValues<StatusEnum>())
                {
                    <option value="@status">@GetStatusLabel(status)</option>
                }
            </InputSelect>
        </div>
        <button type="submit" class="btn btn-warning">Update</button>
    </EditForm>
}

@code {
    [Parameter]
    public Guid id { get; set; }
    private ProjectDto project;
    private string message;
    private string alertClass;

    private static string GetStatusLabel(StatusEnum status) => status switch
    {
        StatusEnum.Active => "Active",
        StatusEnum.Inactive => "Inactive",
        _ => status.ToString()
    };

    protected override async Task OnInitializedAsync()
    {
        project = await ProjectService.Get(id);
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            var result = await ProjectService.Update(project);
            Navigation.NavigateTo("/projects/" + id);
        }
        catch (Exception ex)
        {
            message = $"Error updating project: {ex.Message}";
            alertClass = "alert alert-danger";
        }
    }
}
