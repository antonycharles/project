@page "/"
@page "/projects"
@using Microsoft.AspNetCore.Authorization
@inject ProjectService projectsService
@inject NavigationManager Navigation

@attribute [Authorize]

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Projects</h3>
    <a href="/projects/create" class="btn btn-success">New Project</a>
</div>

@if (list is null)
{
    <p>Loading…</p>
}
else if (list.Count == 0)
{
    <div class="card border-0 shadow-sm">
        <div class="card-body py-4 text-center text-muted">
            No projects found.
        </div>
    </div>
}
else
{
    <div class="row g-4 project-card-grid">
        @foreach (var p in list)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 border-0 shadow-sm project-card"
                     role="link"
                     tabindex="0"
                     @onclick="@(() => GoToDetails(p.Id))"
                     @onkeydown="@((KeyboardEventArgs e) => HandleCardKeyDown(e, p.Id))">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <div>
                                <h5 class="card-title mb-1">@p.Name</h5>
                                <p class="text-muted small mb-0">Project</p>
                            </div>
                            <span class="badge bg-secondary border">Active</span>
                        </div>

                        <p class="card-text text-muted flex-grow-1">@(string.IsNullOrWhiteSpace(p.Description) ? "No description provided." : p.Description)</p>

                        <div class="d-flex flex-wrap gap-2 pt-2 border-top">
                            <a href="/projects/@p.Id" class="btn btn-primary btn-sm">Details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ProjectDto> list;

    protected override async Task OnInitializedAsync()
    {
        list = await projectsService.GetAll();
    }

    private void GoToDetails(Guid projectId)
    {
        Navigation.NavigateTo($"/projects/{projectId}");
    }

    private void HandleCardKeyDown(KeyboardEventArgs e, Guid projectId)
    {
        if (e.Key is "Enter" or " ")
        {
            GoToDetails(projectId);
        }
    }
}
