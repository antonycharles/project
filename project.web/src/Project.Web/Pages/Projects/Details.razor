@page "/projects/{id:guid}"
@inject ProjectService ProjectService
@inject NavigationManager Navigation

<h3>Project Details</h3>

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert @alertClass mb-3">@message</div>
}

@if (project == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h5 class="card-title mb-1">@project.Name</h5>
                    <p class="text-muted mb-0">Project overview</p>
                </div>
                <span class="badge bg-secondary border">Active</span>
            </div>

            <p class="card-text mb-4"><strong>Description:</strong> @(string.IsNullOrWhiteSpace(project.Description) ? "No description provided." : project.Description)</p>

            <div class="d-flex flex-wrap gap-2">
                <a href="/projects/update/@project.Id" class="btn btn-warning">Edit</a>
                <a href="/members/project/@project.Id" class="btn btn-info">Members</a>
                <button type="button" class="btn btn-danger" @onclick="OpenDeleteModal">Delete</button>
                <a href="/projects" class="btn btn-outline-secondary">Back to List</a>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && project is not null)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Project</h5>
                    <button type="button" class="btn-close" aria-label="Close" @onclick="CloseDeleteModal" disabled="@isDeleting"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">Are you sure you want to delete <strong>@project.Name</strong>? This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CloseDeleteModal" disabled="@isDeleting">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@isDeleting">
                        @(isDeleting ? "Deleting..." : "Delete")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public Guid id { get; set; }
    private ProjectDto? project;
    private string? message;
    private string alertClass = "alert-danger";
    private bool showDeleteModal;
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        project = await ProjectService.Get(id);
    }

    private void OpenDeleteModal()
    {
        message = null;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        if (isDeleting)
        {
            return;
        }

        showDeleteModal = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (project is null || isDeleting)
        {
            return;
        }

        try
        {
            isDeleting = true;
            await ProjectService.Delete(project.Id);
            Navigation.NavigateTo("/projects");
        }
        catch (Exception ex)
        {
            showDeleteModal = false;
            message = $"Error deleting project: {ex.Message}";
            alertClass = "alert-danger";
        }
        finally
        {
            isDeleting = false;
        }
    }
}
