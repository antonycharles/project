@model UserDetailsViewModel
@{
    ViewData["Title"] = "User";
}
<nav class="navbar bg-body-tertiary">
  <div class="container-fluid">
    <h1 class="navbar-brand fs-3">@Model.User.Name</h1>
    <div class="d-flex">
      <button onclick="window.history.back()" type="button" class="btn btn-light me-2">Return</button>
    </div>
  </div>
</nav>

@if(User.IsInRole(RoleConstants.UserProfileRole.Create))
{
  <form asp-action="AddProfile" method="post" class="mb-3 d-flex gap-2 align-items-end">
    <input type="hidden" name="userId" value="@Model.User.Id" />
    <div style="min-width:300px;">
      <label class="form-label">Profile</label>
      <select name="profileId" class="form-select" required>
        <option value="">Select...</option>
        @foreach (var profile in Model.AvailableProfiles.OrderBy(p => p.AppName).ThenBy(p => p.Name))
        {
          <option value="@profile.Id">@profile.AppName - @profile.Name</option>
        }
      </select>
    </div>
    <button type="submit" class="btn btn-primary">Add profile</button>
  </form>
}

<table class="table">
  <thead>
    <tr>
      <th scope="col">Profile</th>
      <th scope="col">App</th>
      <th scope="col">Status</th>
      <th scope="col" class="text-end"></th>
    </tr>
  </thead>
  <tbody>
    @if(Model.User.Profiles != null && Model.User.Profiles.Count > 0){
        @foreach(var userProfile in Model.User.Profiles.OrderBy(o => o.Profile?.AppName).ThenBy(o => o.Profile?.Name))
        {
            <tr>
                <td class="align-middle">@userProfile.Profile?.Name</td>
                <td class="align-middle">@userProfile.Profile?.AppName</td>
                <td class="align-middle" style="max-width: 220px;">
                  @if(User.IsInRole(RoleConstants.UserProfileRole.Update))
                  {
                    <form asp-action="UpdateProfileStatus" method="post" class="d-flex gap-2">
                      <input type="hidden" name="userId" value="@Model.User.Id" />
                      <input type="hidden" name="userProfileId" value="@userProfile.Id" />
                      <input type="hidden" name="profileId" value="@userProfile.ProfileId" />
                      <select name="status" class="form-select form-select-sm">
                        @foreach(var val in Enum.GetValues<StatusEnum>())
                        {
                          var isSelected = val == userProfile.Status;
                          <option value="@((int)val)" selected="@isSelected">@val.GetDisplayName()</option>
                        }
                      </select>
                      <button type="submit" class="btn btn-outline-secondary btn-sm">Save</button>
                    </form>
                  }
                  else
                  {
                    @userProfile.Status.GetDisplayName()
                  }
                </td>
                <td class="align-middle text-end">
                  @if(User.IsInRole(RoleConstants.UserProfileRole.Delete))
                  {
                    <form asp-action="DeleteProfile" method="post" onsubmit="return confirm('Remove this profile?');">
                      <input type="hidden" name="userId" value="@Model.User.Id" />
                      <input type="hidden" name="userProfileId" value="@userProfile.Id" />
                      <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                  }
                </td>
            </tr>
        }
    }else{
        <tr>
            <td colspan="4">No records found!</td>
        </tr>
    }
  </tbody>
</table>
