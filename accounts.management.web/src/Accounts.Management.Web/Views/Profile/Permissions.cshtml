@model ProfilePermissionManagementViewModel
@{
    ViewData["Title"] = "Profile permissions";
}
<nav class="navbar bg-body-tertiary">
  <div class="container-fluid">
    <div>
      <h1 class="navbar-brand fs-3 mb-0">@Model.Profile.Name - permissions</h1>
      <div class="text-muted small">@Model.Profile.AppName</div>
    </div>
    <div class="d-flex gap-2">
      <a asp-action="Index" asp-route-appId="@Model.AppId" class="btn btn-light">Return</a>
    </div>
  </div>
</nav>

<form asp-action="Permissions" method="post">
  <input type="hidden" asp-for="ProfileId" />
  <input type="hidden" asp-for="AppId" />
  <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

  <div class="card">
    <div class="card-body">
      @if(Model.AvailablePermissions?.Items != null && Model.AvailablePermissions.Items.Count > 0)
      {
        <div class="row">
          @foreach (var permission in Model.AvailablePermissions.Items.OrderBy(p => p.Name))
          {
            var isChecked = Model.PermissionIds.Contains(permission.Id);
            <div class="col-md-6 mb-3">
              <label class="border rounded p-3 d-block h-100">
                <input
                  class="form-check-input me-2"
                  type="checkbox"
                  name="PermissionIds"
                  value="@permission.Id"
                  checked="@isChecked" />
                <span class="fw-semibold">@permission.Name</span>
                <span class="d-block text-muted small mt-1">@permission.Role</span>
                <span class="d-block small mt-1">Status: @permission.Status.GetDisplayName()</span>
              </label>
            </div>
          }
        </div>
      }
      else
      {
        <div>No permissions found for this app.</div>
      }
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a asp-action="Index" asp-route-appId="@Model.AppId" class="btn btn-light">Cancel</a>
    <button type="submit" class="btn btn-primary">Save permissions</button>
  </div>
</form>
