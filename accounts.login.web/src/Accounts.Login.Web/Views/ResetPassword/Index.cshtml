@{
    ViewData["Title"] = "Reset yout password";
}

<form class="form-signin">
    <h1 class="h3 mb-3">Reset your password</h1>
    <div class="form-floating">
      <input name="Email" class="form-control" id="floatingInput" placeholder="">
      <label>Email</label>
    </div>    
    <div class="mb-4"></div>
    <button class="w-100 btn btn-lg btn-primary" type="submit">Reset password</button>
    <hr/>
    <a asp-controller="Login" class="w-100 btn btn-link btn-sm mt-2 fw-bolder">Return to login</a>
</form>
