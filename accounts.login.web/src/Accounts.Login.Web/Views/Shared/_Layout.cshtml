<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project.Sync </title>
      <link rel="icon" type="image/x-icon" href="@ViewData["FileApiUrlPublic"]/imgs/favicon_io/favicon.ico">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="~/lib/bootstrap/dist/css/bootstrap.css" rel="stylesheet">
    <link rel="stylesheet" href="@ViewData["FileApiUrlPublic"]/css/base.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Accounts.Login.Web.styles.css" asp-append-version="true" />

</head>
<body class="login text-center">
    <main class="form-signin">
        <div>
            <img src="@ViewData["FileApiUrlPublic"]/imgs/logo-project-sync.png" alt="" style="width: 50%;">
            <hr/>
            <div>
                @RenderBody()
            </div>
            <footer>

                <p class="mt-5 mb-3 text-muted">© 2024–2025</p>
            </footer>
        </div>
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_ModalSuccessResponse")
    @await Html.PartialAsync("_ModalErrorResponse")
</body>
</html>
