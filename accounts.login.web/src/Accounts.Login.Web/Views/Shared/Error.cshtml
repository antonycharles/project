@model ErrorViewModel
@{
    ViewData["Title"] = Model.Title;
}

<section class="error-page">
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-exclamation-octagon"></i>
        </div>
        <p class="error-eyebrow">Falha na operação</p>
        <h1>@Model.Title</h1>
        <p class="error-message">@Model.Message</p>

        <div class="error-actions">
            <a href="@Model.ReturnUrl" class="btn btn-primary">@Model.ReturnLabel</a>
            <a asp-controller="Login" asp-action="Index" class="btn btn-outline-secondary">Acessar login</a>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="error-request-id">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
    </div>
</section>
